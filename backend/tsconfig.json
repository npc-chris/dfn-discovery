// TypeScript configuration for backend workspace

{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "allowImportingTsExtensions": true,
    "moduleResolution": "node",
    "preserveSymlinks": false
  },
  "include": ["src"],
  "ts-node": {
    "esm": true,
    "experimentalEsm": true
  }
}

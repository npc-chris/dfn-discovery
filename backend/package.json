{
  "name": "@dfn/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test:core": "ts-node src/services/core-intelligence.test.ts",
    "test:adapters": "ts-node src/services/ai-providers/adapter.test.ts",
    "test:scoring": "ts-node src/routes/scoring.test.ts",
    "test:core:run": "npm run build && node dist/services/core-intelligence.test.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@dfn/shared": "file:../shared",
    "@google/genai": "^2.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.28.0",
    "express": "^4.18.0",
    "ioredis": "^5.3.0",
    "openai": "^6.37.0",
    "pg": "^8.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
